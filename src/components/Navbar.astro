---
import { courseCategories, site } from "../lib/site-data";

const navItems = [
	{ href: "/", label: "Trang chủ" },
	{ href: "/gioi-thieu", label: "Giới thiệu" },
	{ href: "/khoa-hoc", label: "Khóa học" },
	{ href: "/giang-vien", label: "Giảng viên" },
	{ href: "/tin-tuc", label: "Tin tức" },
	{ href: "/lien-he", label: "Liên hệ" },
];
---

<header class="site-header">
	<div class="nav-shell">
		<a href="/" class="brand" aria-label={`${site.name} homepage`}>
			<span class="brand-mark"><i class="fa-solid fa-graduation-cap"></i></span>
			<span>
				<strong>{site.shortName}</strong>
				<small>Tech Academy</small>
			</span>
		</a>

		<button class="nav-toggle" type="button" aria-label="Mở menu" aria-controls="primary-nav">
			<i class="fa-solid fa-bars"></i>
		</button>

		<nav id="primary-nav" class="primary-nav" aria-label="Điều hướng chính">
			{
				navItems.map((item) =>
					item.href === "/khoa-hoc" ? (
						<div class="nav-dropdown">
							<a href={item.href}>{item.label}</a>
							<div class="dropdown-panel">
								{courseCategories.map((category) => (
									<a href={category.href} class="dropdown-item">
										<i class={category.icon} style={`color: ${category.accent}`} />
										<span>
											<strong>{category.title}</strong>
											<small>{category.description}</small>
										</span>
									</a>
								))}
							</div>
						</div>
					) : (
						<a href={item.href}>{item.label}</a>
					),
				)
			}
		</nav>

		<a href="/dang-ky-tu-van" class="btn btn-primary nav-cta">Đăng ký tư vấn</a>
	</div>
</header>

<script>
	const navToggle = document.querySelector(".nav-toggle");
	const nav = document.querySelector(".primary-nav");

	if (navToggle instanceof HTMLButtonElement && nav instanceof HTMLElement) {
		navToggle.addEventListener("click", () => {
			nav.classList.toggle("is-open");
			navToggle.setAttribute("aria-expanded", String(nav.classList.contains("is-open")));
		});
	}
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		border-bottom: 1px solid rgb(226 232 240 / 0.8);
		background: rgb(255 255 255 / 0.88);
		backdrop-filter: blur(16px);
	}

	.nav-shell {
		width: min(1180px, calc(100% - 40px));
		min-height: 76px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 22px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 11px;
		text-decoration: none;
		min-width: 190px;
	}

	.brand-mark {
		width: 42px;
		height: 42px;
		display: inline-grid;
		place-items: center;
		border-radius: 8px;
		background: linear-gradient(135deg, var(--primary), var(--secondary));
		color: #fff;
		box-shadow: 0 12px 28px rgb(37 99 235 / 0.24);
	}

	.brand strong,
	.brand small {
		display: block;
		line-height: 1.1;
	}

	.brand strong {
		font-size: 1.05rem;
	}

	.brand small {
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 700;
	}

	.primary-nav {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
	}

	.primary-nav > a,
	.nav-dropdown > a {
		display: inline-flex;
		align-items: center;
		min-height: 42px;
		padding: 0 12px;
		border-radius: 8px;
		color: #334155;
		font-size: 0.94rem;
		font-weight: 800;
		text-decoration: none;
	}

	.primary-nav > a:hover,
	.nav-dropdown:hover > a {
		background: rgb(37 99 235 / 0.08);
		color: var(--primary);
	}

	.nav-dropdown {
		position: relative;
	}

	.dropdown-panel {
		position: absolute;
		top: calc(100% + 12px);
		left: 50%;
		width: min(640px, calc(100vw - 32px));
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 10px;
		padding: 14px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		box-shadow: var(--shadow-md);
		opacity: 0;
		pointer-events: none;
		transform: translate(-50%, 8px);
		transition: opacity 160ms ease, transform 160ms ease;
	}

	.nav-dropdown:hover .dropdown-panel,
	.nav-dropdown:focus-within .dropdown-panel {
		opacity: 1;
		pointer-events: auto;
		transform: translate(-50%, 0);
	}

	.dropdown-item {
		display: flex;
		gap: 12px;
		padding: 12px;
		border-radius: 8px;
		text-decoration: none;
	}

	.dropdown-item:hover {
		background: var(--soft);
	}

	.dropdown-item i {
		margin-top: 4px;
	}

	.dropdown-item strong,
	.dropdown-item small {
		display: block;
	}

	.dropdown-item small {
		color: var(--muted);
		font-size: 0.82rem;
		line-height: 1.4;
	}

	.nav-toggle {
		display: none;
		margin-left: auto;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		color: var(--ink);
		width: 42px;
		height: 42px;
	}

	.nav-cta {
		white-space: nowrap;
	}

	@media (max-width: 980px) {
		.nav-shell {
			width: min(100% - 28px, 1180px);
			flex-wrap: wrap;
			min-height: 70px;
			padding: 10px 0;
		}

		.nav-toggle {
			display: inline-grid;
			place-items: center;
		}

		.primary-nav {
			order: 4;
			display: none;
			width: 100%;
			align-items: stretch;
			justify-content: start;
			flex-direction: column;
			padding: 10px 0;
		}

		.primary-nav.is-open {
			display: flex;
		}

		.primary-nav > a,
		.nav-dropdown > a {
			width: 100%;
			justify-content: space-between;
			padding: 0 4px;
		}

		.nav-dropdown {
			width: 100%;
		}

		.dropdown-panel {
			position: static;
			width: 100%;
			grid-template-columns: 1fr;
			box-shadow: none;
			opacity: 1;
			pointer-events: auto;
			transform: none;
			padding: 6px 0 8px;
			border: 0;
		}

		.nav-cta {
			display: none;
		}
	}
</style>
