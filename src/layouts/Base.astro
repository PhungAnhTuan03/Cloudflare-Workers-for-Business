---
import "../styles/global.css";
import { EmDashBodyEnd, EmDashBodyStart, EmDashHead } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import { site } from "../lib/site-data";

type ContentContext = {
	collection: string;
	id: string;
	slug?: string | null;
};

interface Props {
	title?: string;
	pageTitle?: string;
	description?: string;
	canonical?: string;
	image?: string;
	content?: ContentContext;
	schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title = `${site.name} - Đào tạo công nghệ thực chiến`,
	pageTitle = title,
	description = site.description,
	canonical = Astro.url.href,
	image = "https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=1200&q=80",
	content,
	schema,
} = Astro.props;

const page = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: content ? "article" : "website",
	title,
	pageTitle,
	description,
	canonical,
	image,
	content,
	siteName: site.name,
	siteUrl: Astro.url.origin,
});

const jsonLd = schema ? JSON.stringify(schema).replaceAll("</", "<\\/") : "";
---

<!doctype html>
<html lang="vi">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="theme-color" content="#2563EB" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
			rel="stylesheet"
		/>
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
		/>
		<EmDashHead page={page} />
		{jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} />}
		<slot name="head" />
	</head>
	<body>
		<EmDashBodyStart page={page} />
		<slot />
		<EmDashBodyEnd page={page} />
	</body>
</html>
