---
import Navbar from "../components/Navbar.astro";
import { courseCategories, site } from "../lib/site-data";
import Base from "./Base.astro";

interface Props {
	title?: string;
	pageTitle?: string;
	description?: string;
	canonical?: string;
	image?: string;
	schema?: Record<string, unknown> | Record<string, unknown>[];
}

const props = Astro.props;
---

<Base {...props}>
	<Navbar />
	<main>
		<slot />
	</main>
	<footer class="site-footer">
		<div class="container footer-grid">
			<div class="footer-brand">
				<a href="/" class="footer-logo">
					<span><i class="fa-solid fa-graduation-cap" aria-hidden="true"></i></span>
					<strong>{site.name}</strong>
				</a>
				<p>
					Dao tao cong nghe thuc chien cho hoc vien, nguoi di lam va doanh nghiep muon nang cap
					nang luc so.
				</p>
				<div class="footer-socials" aria-label="Mang xa hoi">
					<a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f" aria-hidden="true"></i></a>
					<a href="#" aria-label="YouTube"><i class="fa-brands fa-youtube" aria-hidden="true"></i></a>
					<a href="#" aria-label="TikTok"><i class="fa-brands fa-tiktok" aria-hidden="true"></i></a>
					<a href="#" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in" aria-hidden="true"></i></a>
				</div>
			</div>

			<div>
				<h2>Khoa hoc</h2>
				{courseCategories.map((category) => <a href={category.href}>{category.title}</a>)}
			</div>

			<div>
				<h2>Academy</h2>
				<a href="/gioi-thieu">Gioi thieu</a>
				<a href="/#giang-vien">Giang vien</a>
				<a href="/marketplace">Marketplace</a>
				<a href="/tin-tuc">Tin tuc</a>
				<a href="/lien-he">Lien he</a>
			</div>

			<div>
				<h2>Lien he</h2>
				<p>{site.address}</p>
				<a href={`tel:${site.phone.replaceAll(" ", "")}`}>{site.phone}</a>
				<a href={`mailto:${site.email}`}>{site.email}</a>
				<a href="/dang-ky-tu-van" class="btn btn-accent footer-cta">Dang ky tu van</a>
			</div>
		</div>
		<div class="container footer-bottom">
			<span>© 2026 {site.name}. All rights reserved.</span>
			<span>Built on Astro, EmDash CMS and Cloudflare Workers.</span>
		</div>
	</footer>
</Base>

<style>
	.site-footer {
		margin-top: 70px;
		padding: 64px 0 24px;
		background:
			linear-gradient(135deg, rgb(37 99 235 / 0.14), transparent 38%),
			#0f172a;
		color: #cbd5e1;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.5fr repeat(3, minmax(0, 1fr));
		gap: 34px;
	}

	.footer-logo {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: #fff;
		text-decoration: none;
	}

	.footer-logo span {
		width: 38px;
		height: 38px;
		display: inline-grid;
		place-items: center;
		border-radius: 10px;
		background: linear-gradient(135deg, var(--primary), var(--secondary));
		box-shadow: 0 14px 30px rgb(37 99 235 / 0.28);
	}

	.footer-brand p {
		max-width: 360px;
		color: #94a3b8;
	}

	.site-footer h2 {
		margin: 0 0 14px;
		color: #fff;
		font-size: 1rem;
	}

	.site-footer a {
		display: block;
		margin: 9px 0;
		color: #cbd5e1;
		text-decoration: none;
		transition:
			color 300ms ease,
			transform 300ms ease;
	}

	.site-footer a:hover {
		color: #fff;
		transform: translateX(2px);
	}

	.footer-socials {
		display: flex;
		gap: 10px;
		margin-top: 18px;
	}

	.footer-socials a {
		width: 38px;
		height: 38px;
		display: inline-grid;
		place-items: center;
		margin: 0;
		border: 1px solid rgb(255 255 255 / 0.12);
		border-radius: 999px;
		transition:
			transform 300ms ease,
			background 300ms ease,
			border-color 300ms ease;
	}

	.footer-socials a:hover {
		transform: translateY(-3px);
		border-color: rgb(255 255 255 / 0.28);
		background: rgb(255 255 255 / 0.08);
	}

	.footer-cta {
		display: inline-flex !important;
		margin-top: 14px !important;
		color: #111827 !important;
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		gap: 18px;
		margin-top: 42px;
		padding-top: 22px;
		border-top: 1px solid rgb(255 255 255 / 0.12);
		color: #94a3b8;
		font-size: 0.9rem;
	}

	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
		}

		.footer-bottom {
			display: grid;
		}
	}

	@media (max-width: 560px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
