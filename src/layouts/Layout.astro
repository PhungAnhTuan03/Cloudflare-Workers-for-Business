---
import Navbar from "../components/Navbar.astro";
import { courseCategories, site } from "../lib/site-data";
import Base from "./Base.astro";

interface Props {
	title?: string;
	pageTitle?: string;
	description?: string;
	canonical?: string;
	image?: string;
	schema?: Record<string, unknown> | Record<string, unknown>[];
}

const props = Astro.props;
---

<Base {...props}>
	<Navbar />
	<main>
		<slot />
	</main>
	<footer class="site-footer">
		<div class="container footer-grid">
			<div class="footer-brand">
				<a href="/" class="footer-logo">
					<span><i class="fa-solid fa-graduation-cap"></i></span>
					<strong>{site.name}</strong>
				</a>
				<p>
					Đào tạo công nghệ thực chiến cho học viên, người đi làm và doanh nghiệp
					muốn nâng cấp năng lực số.
				</p>
				<div class="footer-socials" aria-label="Mạng xã hội">
					<a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
					<a href="#" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
					<a href="#" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
				</div>
			</div>

			<div>
				<h2>Khóa học</h2>
				{courseCategories.map((category) => <a href={category.href}>{category.title}</a>)}
			</div>

			<div>
				<h2>Trung tâm</h2>
				<a href="/gioi-thieu">Giới thiệu</a>
				<a href="/giang-vien">Giảng viên</a>
				<a href="/tin-tuc">Tin tức</a>
				<a href="/lien-he">Liên hệ</a>
			</div>

			<div>
				<h2>Liên hệ</h2>
				<p>{site.address}</p>
				<a href={`tel:${site.phone.replaceAll(" ", "")}`}>{site.phone}</a>
				<a href={`mailto:${site.email}`}>{site.email}</a>
				<a href="/dang-ky-tu-van" class="btn btn-accent footer-cta">Đăng ký tư vấn</a>
			</div>
		</div>
		<div class="container footer-bottom">
			<span>© 2026 {site.name}. All rights reserved.</span>
			<span>Built on Astro, EmDash CMS and Cloudflare Workers.</span>
		</div>
	</footer>
</Base>

<style>
	.site-footer {
		margin-top: 70px;
		padding: 58px 0 24px;
		background: #0f172a;
		color: #cbd5e1;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.5fr repeat(3, minmax(0, 1fr));
		gap: 34px;
	}

	.footer-logo {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: #fff;
		text-decoration: none;
	}

	.footer-logo span {
		width: 38px;
		height: 38px;
		display: inline-grid;
		place-items: center;
		border-radius: 8px;
		background: linear-gradient(135deg, var(--primary), var(--secondary));
	}

	.footer-brand p {
		max-width: 360px;
		color: #94a3b8;
	}

	.site-footer h2 {
		margin: 0 0 14px;
		color: #fff;
		font-size: 1rem;
	}

	.site-footer a {
		display: block;
		margin: 9px 0;
		color: #cbd5e1;
		text-decoration: none;
	}

	.site-footer a:hover {
		color: #fff;
	}

	.footer-socials {
		display: flex;
		gap: 10px;
		margin-top: 18px;
	}

	.footer-socials a {
		width: 38px;
		height: 38px;
		display: inline-grid;
		place-items: center;
		margin: 0;
		border: 1px solid rgb(255 255 255 / 0.12);
		border-radius: 8px;
	}

	.footer-cta {
		display: inline-flex !important;
		margin-top: 14px !important;
		color: #111827 !important;
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		gap: 18px;
		margin-top: 42px;
		padding-top: 22px;
		border-top: 1px solid rgb(255 255 255 / 0.12);
		color: #94a3b8;
		font-size: 0.9rem;
	}

	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
		}

		.footer-bottom {
			display: grid;
		}
	}

	@media (max-width: 560px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
