---
import Layout from "../layouts/Layout.astro";
import { site } from "../lib/site-data";
---

<Layout
	title={`Khoa hoc giang vien - ${site.name}`}
	description="Marketplace khoa hoc do giang vien dang ban."
>
	<section class="market-section">
		<div class="container">
			<div class="market-hero">
				<span class="page-kicker">
					<i class="fa-solid fa-store" aria-hidden="true"></i>
					Marketplace
				</span>
				<h1>Chon khoa hoc phu hop va vao hoc ngay sau khi mua.</h1>
				<p>Tim theo ky nang, so sanh hoc phi, xem profile giang vien va mua khoa hoc online.</p>
			</div>

			<form class="market-toolbar card" data-market-filter>
				<div class="field search-field">
					<label for="market-q">Tim khoa hoc</label>
					<input id="market-q" name="q" type="search" placeholder="Nhap ten khoa hoc, ky nang, giang vien..." />
				</div>
				<div class="field">
					<label for="market-max">Gia toi da</label>
					<select id="market-max" name="maxPrice">
						<option value="">Tat ca</option>
						<option value="300000">Duoi 300k</option>
						<option value="500000">Duoi 500k</option>
						<option value="1000000">Duoi 1 trieu</option>
					</select>
				</div>
				<div class="field">
					<label for="market-sort">Sap xep</label>
					<select id="market-sort" name="sort">
						<option value="newest">Moi nhat</option>
						<option value="price_asc">Gia thap</option>
						<option value="price_desc">Gia cao</option>
					</select>
				</div>
				<button class="btn btn-primary" type="submit">
					<i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
					Tim
				</button>
				<a class="btn btn-secondary" href="/gio-hang">
					<i class="fa-solid fa-cart-shopping" aria-hidden="true"></i>
					Gio hang
				</a>
			</form>

			<div class="market-grid" data-market-courses></div>
		</div>
	</section>
</Layout>

<script>
	const target = document.querySelector("[data-market-courses]");
	const filterForm = document.querySelector("[data-market-filter]");

	type Course = {
		public_id: string;
		title: string;
		description: string;
		price: number;
		cover_url?: string | null;
		instructor_public_id: string;
		instructor_name: string;
	};
	type ApiResult = {
		ok?: boolean;
		message?: string;
		courses?: Course[];
	};

	function buildQuery() {
		if (!(filterForm instanceof HTMLFormElement)) return "";
		const params = new URLSearchParams();
		for (const [key, value] of new FormData(filterForm)) {
			if (typeof value === "string" && value.trim()) params.set(key, value.trim());
		}
		return params.toString();
	}

	async function addToCart(id: string | null) {
		const response = await fetch("/api/cart", {
			method: "POST",
			headers: { "Content-Type": "application/json" },
			body: JSON.stringify({ courseId: id }),
		});
		const result = (await response.json()) as ApiResult;
		alert(result.message || (response.ok ? "Da them vao gio hang." : "Khong them duoc."));
	}

	async function buyNow(id: string | null) {
		await addToCart(id);
		window.location.href = "/gio-hang";
	}

	async function loadCourses() {
		const query = buildQuery();
		const response = await fetch(`/api/marketplace/courses${query ? `?${query}` : ""}`);
		const result = (await response.json()) as ApiResult;
		const courses = result.courses || [];

		if (!(target instanceof HTMLElement)) return;
		if (!courses.length) {
			target.innerHTML = "<p class='empty'>Chua co khoa hoc phu hop.</p>";
			return;
		}

		target.innerHTML = courses
			.map(
				(course) => `
					<article class="market-card">
						<div class="course-cover">
							${
								course.cover_url
									? `<img src="${course.cover_url}" alt="${course.title}" />`
									: `<div class="cover-fallback"><i class="fa-solid fa-graduation-cap" aria-hidden="true"></i></div>`
							}
							<span class="course-badge">Moi</span>
						</div>
						<div class="market-card-body">
							<a class="instructor-link" href="/ho-so/${course.instructor_public_id}">${course.instructor_name}</a>
							<h2>${course.title}</h2>
							<p>${course.description}</p>
							<div class="course-facts">
								<small><i class="fa-solid fa-star"></i> Moi dang ban</small>
								<small><i class="fa-solid fa-file-lines"></i> Co tai lieu</small>
								<small><i class="fa-solid fa-message"></i> Nhan tin rieng</small>
							</div>
							<strong class="course-price">${Number(course.price).toLocaleString("vi-VN")}d</strong>
							<div class="market-actions">
								<a class="btn btn-primary" href="/khoa-hoc-giang-vien/${course.public_id}">Xem chi tiet</a>
								<button class="btn btn-secondary" data-cart="${course.public_id}">Them gio</button>
								<button class="btn btn-accent" data-buy="${course.public_id}">Mua ngay</button>
							</div>
						</div>
					</article>
				`,
			)
			.join("");

		for (const button of document.querySelectorAll("[data-cart]")) {
			if (!(button instanceof HTMLButtonElement)) continue;
			button.addEventListener("click", () => addToCart(button.getAttribute("data-cart")));
		}

		for (const button of document.querySelectorAll("[data-buy]")) {
			if (!(button instanceof HTMLButtonElement)) continue;
			button.addEventListener("click", () => buyNow(button.getAttribute("data-buy")));
		}
	}

	if (filterForm instanceof HTMLFormElement) {
		filterForm.addEventListener("submit", (event) => {
			event.preventDefault();
			loadCourses();
		});
	}

	loadCourses();
</script>

<style>
	.market-section {
		padding: 46px 0 40px;
	}

	.market-section .container {
		width: min(1200px, calc(100% - 40px));
	}

	.market-hero {
		max-width: 760px;
	}

	.market-hero h1 {
		margin: 0;
		font-size: clamp(2.1rem, 4vw, 3.4rem);
		line-height: 1.08;
		letter-spacing: 0;
	}

	.market-hero p,
	.empty {
		color: var(--muted);
	}

	.market-toolbar {
		display: grid;
		grid-template-columns: minmax(260px, 1fr) 150px 150px auto auto;
		gap: 12px;
		align-items: end;
		margin-top: 24px;
		padding: 14px;
		border-radius: 20px;
	}

	.market-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
		gap: 20px;
		margin-top: 24px;
	}

	.market-card {
		overflow: hidden;
		display: grid;
		border: 1px solid var(--line);
		border-radius: 20px;
		background: #fff;
		box-shadow: var(--shadow-sm);
		transition: transform 300ms ease, box-shadow 300ms ease, border-color 300ms ease;
	}

	.market-card:hover {
		transform: translateY(-4px);
		border-color: rgb(37 99 235 / 0.22);
		box-shadow: var(--shadow-md);
	}

	.course-cover {
		position: relative;
		overflow: hidden;
		aspect-ratio: 16 / 9;
		background: linear-gradient(135deg, rgb(37 99 235 / 0.12), rgb(96 165 250 / 0.2));
	}

	.course-cover img,
	.cover-fallback {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.cover-fallback {
		display: grid;
		place-items: center;
		color: var(--primary);
		font-size: 2.3rem;
	}

	.course-badge {
		position: absolute;
		top: 12px;
		left: 12px;
		padding: 6px 9px;
		border-radius: 999px;
		background: rgb(255 255 255 / 0.92);
		color: var(--primary);
		font-size: 0.78rem;
		font-weight: 900;
	}

	.market-card-body {
		display: grid;
		gap: 10px;
		padding: 16px;
	}

	.instructor-link {
		width: fit-content;
		color: var(--primary);
		font-size: 0.9rem;
		font-weight: 900;
		text-decoration: none;
	}

	.market-card h2 {
		margin: 0;
		font-size: 1.18rem;
		line-height: 1.35;
	}

	.market-card p {
		display: -webkit-box;
		margin: 0;
		overflow: hidden;
		color: var(--muted);
		font-size: 0.95rem;
		line-height: 1.55;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	.course-facts {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin: 0;
	}

	.course-facts small {
		padding: 6px 8px;
		border-radius: 999px;
		background: rgb(37 99 235 / 0.08);
		color: var(--primary);
		font-weight: 800;
	}

	.course-price {
		font-size: 1.25rem;
		line-height: 1;
	}

	.market-actions {
		display: grid;
		grid-template-columns: 1fr 0.9fr 0.9fr;
		gap: 8px;
		margin-top: 2px;
	}

	.market-actions .btn {
		min-height: 42px;
		padding: 10px 12px;
		font-size: 0.92rem;
		white-space: nowrap;
	}

	@media (max-width: 920px) {
		.market-section {
			padding-top: 28px;
		}

		.market-toolbar {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.market-toolbar .search-field,
		.market-toolbar .btn {
			grid-column: 1 / -1;
		}
	}

	@media (max-width: 560px) {
		.market-section .container {
			width: min(100% - 28px, 1200px);
		}

		.market-toolbar,
		.market-actions {
			grid-template-columns: 1fr;
		}
	}
</style>
