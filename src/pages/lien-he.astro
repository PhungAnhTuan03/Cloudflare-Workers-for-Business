---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<section class="page-header contact-hero">
		<div class="container">
			<h1>Liên hệ</h1>
			<p class="section-subhead">
				Gửi thông tin tư vấn, chúng tôi sẽ phản hồi trong thời gian sớm nhất.
			</p>
		</div>
	</section>

	<section class="contact-section">
		<div class="container">
			<div class="contact-grid">
				<aside class="contact-info">
					<h2>Thông tin liên hệ</h2>
					<div class="info-item">
						<i class="fas fa-map-marker-alt" aria-hidden="true"></i>
						<div>
							<strong>Địa chỉ</strong>
							<p>145 Lê Duẩn, phường Bến Nghé, Quận 1, TP. Hồ Chí Minh</p>
						</div>
					</div>
					<div class="info-item">
						<i class="fas fa-phone-alt" aria-hidden="true"></i>
						<div>
							<strong>Điện thoại</strong>
							<p>1900 6369 (8h00 - 21h00)</p>
						</div>
					</div>
					<div class="info-item">
						<i class="fas fa-envelope" aria-hidden="true"></i>
						<div>
							<strong>Email</strong>
							<p>info@saoviet.edu.vn</p>
							<p>tuyensinh@saoviet.edu.vn</p>
						</div>
					</div>
					<div class="info-item">
						<i class="fas fa-clock" aria-hidden="true"></i>
						<div>
							<strong>Giờ làm việc</strong>
							<p>Thứ 2 - Thứ 6: 8h00 - 20h00</p>
							<p>Thứ 7 - Chủ nhật: 8h00 - 17h00</p>
						</div>
					</div>
					<a
						class="map-link"
						href="https://www.google.com/maps/search/?api=1&query=145%20Le%20Duan%20Quan%201%20TP%20Ho%20Chi%20Minh"
						target="_blank"
						rel="noreferrer"
					>
						Xem bản đồ
					</a>
				</aside>

				<div class="contact-form-wrapper">
					<h2>Gửi tin nhắn</h2>
					<form id="contactForm" action="/api/contact" method="POST">
						<div class="form-honeypot" aria-hidden="true">
							<label for="website">Website</label>
							<input
								type="text"
								id="website"
								name="website"
								tabindex="-1"
								autocomplete="off"
							/>
						</div>
						<div class="form-group">
							<label for="name">Họ và tên</label>
							<input type="text" id="name" name="name" autocomplete="name" />
						</div>
						<div class="form-group">
							<label for="email">Email *</label>
							<input type="email" id="email" name="email" autocomplete="email" required />
						</div>
						<div class="form-group">
							<label for="phone">Số điện thoại</label>
							<input type="tel" id="phone" name="phone" autocomplete="tel" />
						</div>
						<div class="form-group">
							<label for="subject">Chủ đề</label>
							<select id="subject" name="subject">
								<option value="">-- Chọn --</option>
								<option value="tu-van">Tư vấn khóa học</option>
								<option value="hoc-phi">Học phí</option>
								<option value="hop-tac">Hợp tác doanh nghiệp</option>
								<option value="khac">Khác</option>
							</select>
						</div>
						<div class="form-group">
							<label for="message">Nội dung *</label>
							<textarea id="message" name="message" rows="5" required></textarea>
						</div>
						<button type="submit" class="btn btn-primary btn-block">Gửi liên hệ</button>
						<p id="formStatus" class="form-status" aria-live="polite"></p>
					</form>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style is:global>
	.contact-hero {
		padding-bottom: 32px;
	}
	.contact-section {
		padding: 48px 0 72px;
	}
	.contact-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
		gap: 40px;
		align-items: start;
	}
	.contact-info,
	.contact-form-wrapper {
		background: var(--card-bg);
		border: 1px solid var(--border-color);
		border-radius: 16px;
		box-shadow: var(--shadow-sm);
		padding: 28px;
	}
	.contact-info h2,
	.contact-form-wrapper h2 {
		font-size: 1.45rem;
		text-align: left;
		margin-bottom: 24px;
	}
	.contact-info h2::after,
	.contact-form-wrapper h2::after {
		margin-left: 0;
		margin-right: auto;
	}
	.info-item {
		display: flex;
		gap: 14px;
		margin-bottom: 22px;
	}
	.info-item i {
		color: var(--primary-blue);
		font-size: 1.15rem;
		margin-top: 4px;
		width: 22px;
		text-align: center;
	}
	.info-item strong {
		display: block;
		margin-bottom: 4px;
	}
	.info-item p {
		color: var(--text-muted);
		margin: 0;
	}
	.map-link {
		color: var(--primary-blue);
		font-weight: 700;
		text-decoration: none;
	}
	.map-link:hover {
		text-decoration: underline;
	}
	.form-group {
		margin-bottom: 18px;
	}
	.form-honeypot {
		position: absolute;
		left: -10000px;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}
	.form-group label {
		display: block;
		margin-bottom: 8px;
		font-weight: 600;
	}
	.form-group input,
	.form-group select,
	.form-group textarea {
		width: 100%;
		padding: 12px 14px;
		border-radius: 10px;
		border: 1px solid var(--border-color);
		background: var(--card-bg);
		color: var(--text-main);
		font: inherit;
	}
	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--primary-blue);
		box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.18);
	}
	.btn-block {
		width: 100%;
		justify-content: center;
	}
	.form-status {
		margin-top: 14px;
		text-align: center;
		font-weight: 600;
		min-height: 1.5em;
	}
	.form-status[data-state="error"] {
		color: #c0392b;
	}
	.form-status[data-state="success"] {
		color: var(--success-green);
	}
	@media (max-width: 800px) {
		.contact-grid {
			grid-template-columns: 1fr;
		}
		.contact-info,
		.contact-form-wrapper {
			padding: 22px;
		}
	}
</style>

<script>
	const form = document.getElementById("contactForm");
	const status = document.getElementById("formStatus");

	if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
		form.addEventListener("submit", async (event) => {
			event.preventDefault();

			const submitButton = form.querySelector("button[type='submit']");
			if (submitButton instanceof HTMLButtonElement) {
				submitButton.disabled = true;
			}
			status.dataset.state = "";
			status.textContent = "Đang gửi...";

			try {
				const body = new URLSearchParams();
				for (const [key, value] of new FormData(form).entries()) {
					if (typeof value === "string") {
						body.append(key, value);
					}
				}

				const response = await fetch("/api/contact", {
					method: "POST",
					body,
					headers: {
						"Content-Type": "application/x-www-form-urlencoded;charset=UTF-8",
					},
				});
				const result = (await response.json().catch(() => ({}))) as {
					ok?: boolean;
					message?: string;
				};

				if (!response.ok) {
					throw new Error(result.message || "Không gửi được liên hệ.");
				}

				status.dataset.state = "success";
				status.textContent = result.message || "Gửi thành công. Chúng tôi sẽ liên hệ lại sớm.";
				form.reset();
			} catch (error) {
				status.dataset.state = "error";
				status.textContent =
					error instanceof Error ? error.message : "Lỗi kết nối, vui lòng thử lại.";
			} finally {
				if (submitButton instanceof HTMLButtonElement) {
					submitButton.disabled = false;
				}
			}
		});
	}
</script>
