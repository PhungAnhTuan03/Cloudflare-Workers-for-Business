---
import ContactForm from "../components/ContactForm.astro";
import Layout from "../layouts/Layout.astro";
import { site } from "../lib/site-data";

const schema = {
	"@context": "https://schema.org",
	"@type": "ContactPage",
	name: `Liên hệ ${site.name}`,
	url: `${site.url}/lien-he`,
	mainEntity: {
		"@type": "EducationalOrganization",
		name: site.name,
		email: site.email,
		telephone: site.phone,
		address: site.address,
	},
};
---

<Layout
	title={`Liên hệ ${site.name}`}
	description="Gửi thông tin tư vấn khóa học, lịch học, học phí hoặc hợp tác đào tạo doanh nghiệp."
	canonical={`${site.url}/lien-he`}
	schema={schema}
>
	<section class="page-hero contact-hero">
		<div class="container page-hero-grid">
			<div>
				<span class="page-kicker">
					<i class="fa-solid fa-headset" aria-hidden="true"></i>
					Liên hệ trung tâm
				</span>
				<h1 class="page-title">Đội tư vấn luôn sẵn sàng giúp bạn chọn đúng lộ trình.</h1>
				<p class="page-lead">
					Gửi thông tin bên dưới, trung tâm sẽ phản hồi qua email hoặc điện thoại. Mọi liên hệ
					được lưu vào hệ thống D1 và gửi thông báo qua Resend về email quản trị.
				</p>
			</div>
			<div class="contact-card card">
				<h2>Thông tin nhanh</h2>
				<ul>
					<li>
						<i class="fa-solid fa-location-dot" aria-hidden="true"></i>
						<span>{site.address}</span>
					</li>
					<li>
						<i class="fa-solid fa-phone" aria-hidden="true"></i>
						<a href={`tel:${site.phone.replaceAll(" ", "")}`}>{site.phone}</a>
					</li>
					<li>
						<i class="fa-solid fa-envelope" aria-hidden="true"></i>
						<a href={`mailto:${site.email}`}>{site.email}</a>
					</li>
					<li>
						<i class="fa-solid fa-clock" aria-hidden="true"></i>
						<span>Thứ 2 - Chủ nhật, 8:00 - 21:00</span>
					</li>
				</ul>
			</div>
		</div>
	</section>

	<section class="section contact-section">
		<div class="container contact-grid">
			<div class="contact-copy">
				<p class="section-eyebrow">Tư vấn cá nhân hóa</p>
				<h2 class="section-title">Bạn đang cần học gì?</h2>
				<p class="section-lead">
					Chọn khóa học quan tâm hoặc ghi rõ mục tiêu của bạn. Mentor sẽ gợi ý lộ trình, lịch
					học, học phí và đầu ra phù hợp.
				</p>

				<div class="support-grid">
					<div class="support-item">
						<i class="fa-solid fa-route" aria-hidden="true"></i>
						<strong>Lộ trình rõ ràng</strong>
						<span>Tư vấn theo mục tiêu và thời gian học thực tế.</span>
					</div>
					<div class="support-item">
						<i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
						<strong>Dữ liệu an toàn</strong>
						<span>Không công khai thông tin liên hệ của học viên.</span>
					</div>
					<div class="support-item">
						<i class="fa-solid fa-reply" aria-hidden="true"></i>
						<strong>Phản hồi nhanh</strong>
						<span>Ưu tiên phản hồi trong ngày làm việc.</span>
					</div>
				</div>
			</div>

			<div class="contact-form-panel card">
				<h2>Gửi yêu cầu tư vấn</h2>
				<ContactForm
					formId="contact-page-form"
					submitLabel="Gửi liên hệ"
					defaultMessage="Tôi muốn được tư vấn khóa học phù hợp với mục tiêu hiện tại."
				/>
			</div>
		</div>
	</section>
</Layout>

<style>
	.contact-card {
		padding: 26px;
	}

	.contact-card h2,
	.contact-form-panel h2 {
		margin: 0 0 18px;
		font-size: 1.35rem;
	}

	.contact-card ul {
		display: grid;
		gap: 16px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.contact-card li {
		display: grid;
		grid-template-columns: 28px 1fr;
		gap: 10px;
		color: var(--muted);
	}

	.contact-card i {
		color: var(--primary);
		margin-top: 4px;
	}

	.contact-card a {
		color: var(--ink);
		font-weight: 800;
		text-decoration: none;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
		gap: 34px;
		align-items: start;
	}

	.support-grid {
		display: grid;
		gap: 14px;
		margin-top: 30px;
	}

	.support-item {
		display: grid;
		grid-template-columns: 42px 1fr;
		gap: 8px 14px;
		align-items: start;
		padding: 16px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: #fff;
	}

	.support-item i {
		grid-row: span 2;
		width: 42px;
		height: 42px;
		display: inline-grid;
		place-items: center;
		border-radius: var(--radius);
		background: rgb(37 99 235 / 0.1);
		color: var(--primary);
	}

	.support-item strong {
		line-height: 1.2;
	}

	.support-item span {
		color: var(--muted);
	}

	.contact-form-panel {
		padding: 28px;
	}

	@media (max-width: 860px) {
		.contact-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
