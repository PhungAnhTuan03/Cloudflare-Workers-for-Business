---
import Layout from "../layouts/Layout.astro";
import { courses, site, testimonials } from "../lib/site-data";

const schema = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	name: "Cảm nhận học viên",
	url: `${site.url}/hoc-vien`,
	description: "Câu chuyện học tập và kết quả của học viên Sao Việt Tech Academy.",
};
---

<Layout
	title="Cảm nhận học viên"
	description="Câu chuyện học tập, phản hồi và kết quả thực tế của học viên sau các khóa đào tạo công nghệ."
	canonical={`${site.url}/hoc-vien`}
	schema={schema}
>
	<section class="page-hero">
		<div class="container">
			<span class="page-kicker">
				<i class="fa-solid fa-star" aria-hidden="true"></i>
				Học viên nói gì?
			</span>
			<h1 class="page-title">Kết quả tốt nhất là khi học viên tự tin làm được việc.</h1>
			<p class="page-lead">
				Một vài phản hồi tiêu biểu từ những người đã học Office, lập trình, thiết kế, AI và
				marketing tại trung tâm.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="container testimonial-grid">
			{testimonials.map((item) => (
				<article class="testimonial-card card">
					<div class="rating">
						<i class="fa-solid fa-star" aria-hidden="true"></i>
						<span>{item.rating}</span>
					</div>
					<p>"{item.content}"</p>
					<div class="student">
						<strong>{item.name}</strong>
						<span>{item.role}</span>
					</div>
				</article>
			))}
		</div>
	</section>

	<section class="section tight outcome-band">
		<div class="container outcome-grid">
			<div>
				<p class="section-eyebrow">Sau khóa học</p>
				<h2 class="section-title">Học viên rời lớp với sản phẩm thật, không chỉ chứng chỉ.</h2>
			</div>
			<div class="outcome-list">
				<div><i class="fa-solid fa-briefcase" aria-hidden="true"></i>Portfolio hoặc bộ bài tập có mentor review.</div>
				<div><i class="fa-solid fa-comments" aria-hidden="true"></i>Nhóm hỗ trợ hỏi đáp sau khóa học.</div>
				<div><i class="fa-solid fa-file-signature" aria-hidden="true"></i>Chứng nhận hoàn thành theo tiêu chí đầu ra.</div>
			</div>
		</div>
	</section>

	<section class="section tight">
		<div class="container">
			<div class="section-head">
				<div>
					<p class="section-eyebrow">Bắt đầu từ đâu?</p>
					<h2 class="section-title">Chọn khóa học phù hợp với mục tiêu hiện tại</h2>
				</div>
				<a href="/dang-ky-tu-van" class="btn btn-primary">Đăng ký tư vấn</a>
			</div>
			<div class="responsive-grid">
				{courses.slice(0, 3).map((course) => (
					<a href={`/khoa-hoc/${course.slug}`} class="mini-course card">
						<img src={course.image} alt={course.title} loading="lazy" />
						<strong>{course.title}</strong>
						<span>{course.duration} • {course.price}</span>
					</a>
				))}
			</div>
		</div>
	</section>
</Layout>

<style>
	.testimonial-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 22px;
	}

	.testimonial-card {
		display: grid;
		align-content: start;
		gap: 18px;
		padding: 24px;
	}

	.rating {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: var(--accent);
		font-weight: 900;
	}

	.testimonial-card p {
		margin: 0;
		color: #334155;
		font-size: 1.02rem;
	}

	.student {
		display: grid;
		gap: 2px;
		padding-top: 16px;
		border-top: 1px solid var(--line);
	}

	.student span,
	.mini-course span {
		color: var(--muted);
	}

	.outcome-band {
		background: #0f172a;
		color: #fff;
	}

	.outcome-band .section-title,
	.outcome-band .section-eyebrow {
		color: #fff;
	}

	.outcome-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(300px, 0.8fr);
		gap: 34px;
		align-items: center;
	}

	.outcome-list {
		display: grid;
		gap: 14px;
	}

	.outcome-list div {
		display: flex;
		gap: 12px;
		padding: 14px;
		border: 1px solid rgb(255 255 255 / 0.14);
		border-radius: var(--radius);
		background: rgb(255 255 255 / 0.06);
		color: #dbeafe;
	}

	.outcome-list i {
		color: var(--accent);
		margin-top: 4px;
	}

	.mini-course {
		overflow: hidden;
		color: inherit;
		text-decoration: none;
	}

	.mini-course img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
	}

	.mini-course strong,
	.mini-course span {
		display: block;
		padding: 0 16px;
	}

	.mini-course strong {
		padding-top: 16px;
	}

	.mini-course span {
		padding-bottom: 16px;
	}

	@media (max-width: 900px) {
		.testimonial-grid,
		.outcome-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
