---
import Layout from "../../layouts/Layout.astro";
import { articles, courseCategories, site } from "../../lib/site-data";

const article = articles.find((item) => item.slug === Astro.params.slug);

if (!article) {
	Astro.response.status = 404;
}

function toIsoDate(value: string): string {
	const [day, month, year] = value.split("/");
	return `${year}-${month}-${day}`;
}

const relatedTopics = courseCategories.slice(0, 4);
const schema = article
	? [
			{
				"@context": "https://schema.org",
				"@type": "BlogPosting",
				headline: article.title,
				description: article.description,
				image: article.image,
				datePublished: toIsoDate(article.date),
				dateModified: toIsoDate(article.date),
				author: {
					"@type": "Organization",
					name: site.name,
				},
				publisher: {
					"@type": "Organization",
					name: site.name,
				},
				mainEntityOfPage: `${site.url}/tin-tuc/${article.slug}`,
			},
			{
				"@context": "https://schema.org",
				"@type": "BreadcrumbList",
				itemListElement: [
					{ "@type": "ListItem", position: 1, name: "Trang chủ", item: site.url },
					{ "@type": "ListItem", position: 2, name: "Tin tức", item: `${site.url}/tin-tuc` },
					{
						"@type": "ListItem",
						position: 3,
						name: article.title,
						item: `${site.url}/tin-tuc/${article.slug}`,
					},
				],
			},
		]
	: undefined;
---

<Layout
	title={article ? article.title : "Không tìm thấy bài viết"}
	description={article ? article.description : "Bài viết không tồn tại hoặc đã được di chuyển."}
	canonical={article ? `${site.url}/tin-tuc/${article.slug}` : `${site.url}/tin-tuc`}
	image={article?.image}
	schema={schema}
>
	{
		article ? (
			<>
				<section class="article-hero">
					<div class="container article-hero-grid">
						<div>
							<nav class="breadcrumb" aria-label="Breadcrumb">
								<a href="/">Trang chủ</a>
								<span>/</span>
								<a href="/tin-tuc">Tin tức</a>
							</nav>
							<div class="news-meta">
								<span>{article.category}</span>
								<span>{article.date}</span>
							</div>
							<h1>{article.title}</h1>
							<p>{article.description}</p>
						</div>
						<img src={article.image} alt={article.title} loading="eager" />
					</div>
				</section>

				<section class="section article-section">
					<div class="container article-layout">
						<article class="article-content card">
							<p class="lead">
								Trong đào tạo công nghệ, điều quan trọng không phải là học thật nhiều công cụ
								một lúc, mà là biết công cụ nào giúp giải quyết đúng vấn đề hiện tại.
							</p>
							<h2>Bắt đầu từ mục tiêu học tập</h2>
							<p>
								Trước khi chọn khóa học, hãy xác định kết quả bạn muốn đạt được: làm việc nhanh
								hơn, xây portfolio, chuyển nghề, hay tối ưu hiệu suất công việc. Khi mục tiêu rõ,
								lộ trình học sẽ gọn và dễ đo lường hơn.
							</p>
							<h2>Ưu tiên thực hành theo tình huống thật</h2>
							<p>
								Kiến thức chỉ thật sự có giá trị khi được áp dụng vào bài tập, dự án hoặc quy
								trình làm việc. Vì vậy mỗi module nên có đầu ra cụ thể: báo cáo, landing page,
								bộ thiết kế, bản vẽ hoặc chiến dịch mẫu.
							</p>
							<h2>Đo tiến độ bằng sản phẩm</h2>
							<p>
								Một lộ trình tốt luôn có tiêu chí đánh giá rõ ràng. Học viên nên lưu lại sản phẩm
								qua từng giai đoạn để thấy kỹ năng đang tiến bộ ra sao và còn thiếu điểm nào.
							</p>
							<div class="article-cta">
								<strong>Cần mentor tư vấn lộ trình?</strong>
								<a href="/dang-ky-tu-van" class="btn btn-primary">Đăng ký tư vấn</a>
							</div>
						</article>

						<aside class="article-sidebar card">
							<h2>Chủ đề liên quan</h2>
							{relatedTopics.map((topic) => (
								<a href={topic.href}>
									<i class={topic.icon} aria-hidden="true" style={`color: ${topic.accent}`}></i>
									<span>{topic.title}</span>
								</a>
							))}
						</aside>
					</div>
				</section>
			</>
		) : (
			<section class="page-hero">
				<div class="container">
					<span class="page-kicker">404</span>
					<h1 class="page-title">Không tìm thấy bài viết.</h1>
					<p class="page-lead">Bài viết có thể đã được di chuyển hoặc chưa được xuất bản.</p>
					<a href="/tin-tuc" class="btn btn-primary">Quay lại tin tức</a>
				</div>
			</section>
		)
	}
</Layout>

<style>
	.article-hero {
		padding: 62px 0 36px;
		background: #fff;
		border-bottom: 1px solid var(--line);
	}

	.article-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 480px);
		gap: 34px;
		align-items: center;
	}

	.breadcrumb {
		display: flex;
		gap: 8px;
		color: var(--muted);
		font-weight: 800;
	}

	.breadcrumb a {
		text-decoration: none;
	}

	.news-meta {
		display: flex;
		gap: 10px;
		margin: 18px 0 12px;
		color: var(--primary);
		font-size: 0.86rem;
		font-weight: 900;
	}

	.article-hero h1 {
		margin: 0;
		font-size: clamp(2.1rem, 4.6vw, 4rem);
		line-height: 1.06;
		letter-spacing: 0;
	}

	.article-hero p {
		color: var(--muted);
		font-size: 1.1rem;
	}

	.article-hero img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-radius: var(--radius);
		box-shadow: var(--shadow-md);
	}

	.article-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: 26px;
		align-items: start;
	}

	.article-content {
		padding: 30px;
	}

	.article-content .lead {
		color: var(--ink);
		font-size: 1.18rem;
		font-weight: 700;
	}

	.article-content h2 {
		margin: 30px 0 10px;
		font-size: 1.6rem;
	}

	.article-content p {
		color: #334155;
	}

	.article-cta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		margin-top: 34px;
		padding: 18px;
		border-radius: var(--radius);
		background: var(--surface-2);
	}

	.article-sidebar {
		position: sticky;
		top: 92px;
		padding: 22px;
	}

	.article-sidebar h2 {
		margin: 0 0 14px;
		font-size: 1.1rem;
	}

	.article-sidebar a {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 12px 0;
		border-top: 1px solid var(--line);
		color: inherit;
		font-weight: 800;
		text-decoration: none;
	}

	@media (max-width: 900px) {
		.article-hero-grid,
		.article-layout {
			grid-template-columns: 1fr;
		}

		.article-sidebar {
			position: static;
		}
	}
</style>
