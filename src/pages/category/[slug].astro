---
import { decodeSlug, getEmDashCollection, getTerm } from "emdash";
import Layout from "../../layouts/Layout.astro";

const slug = decodeSlug(Astro.params.slug);
const term = slug ? await getTerm("category", slug) : null;

if (!term) {
  return Astro.redirect("/404");
}

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
  status: "published",
  where: { category: term.slug },
  orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);
---

<Layout>
  <section class="page-header">
    <div class="container">
      <h1>Chu de: {term.label}</h1>

      <p class="section-subhead">
        Co {posts.length} bai viet trong chu de nay
      </p>
    </div>
  </section>

  <section class="category-posts">
    <div class="container">
      {
        posts.length === 0 ? (
          <p class="text-center">Chua co bai viet nao cho chu de nay.</p>
        ) : (
          <div class="grid-auto">
            {posts.map((post) => (
              <a href={`/posts/${post.id}`} class="card">
                <h3 {...post.edit.title}>{post.data.title}</h3>

                {post.data.excerpt && <p {...post.edit.excerpt}>{post.data.excerpt}</p>}

                <span class="read-more">Xem chi tiet</span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Layout>

<style is:global>
  .category-posts {
    padding: 60px 0;
  }

  .text-center {
    text-align: center;
  }
</style>
