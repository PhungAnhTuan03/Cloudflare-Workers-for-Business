---
import Layout from "../../layouts/Layout.astro";
import { site } from "../../lib/site-data";

const courseId = Astro.params.courseId || "";
---

<Layout
	title={`Tin nhan khoa hoc - ${site.name}`}
	description="Tin nhan rieng giua hoc vien da mua khoa hoc va giang vien phu trach."
>
	<section class="messenger-page">
		<div class="container messenger-shell">
			<aside class="conversation-list card">
				<div class="conversation-head">
					<div>
						<span>Tin nhan</span>
						<h1>Hop thu hoc tap</h1>
					</div>
					<button type="button" aria-label="Tao tin nhan moi">
						<i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
					</button>
				</div>
				<div class="conversation-search">
					<i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
					<input placeholder="Tim mentor, khoa hoc..." aria-label="Tim tin nhan" />
				</div>
				<div class="conversation-items">
					<button class="active" type="button">
						<span class="avatar gradient">SV</span>
						<span>
							<strong data-sidebar-title>Dang tai khoa hoc...</strong>
							<small>Cuoc tro chuyen rieng</small>
						</span>
					</button>
					<button type="button">
						<span class="avatar image-one"></span>
						<span>
							<strong>Mentor Support</strong>
							<small>Ho tro lich hoc va tai lieu</small>
						</span>
					</button>
				</div>
			</aside>

			<main class="chat-panel card">
				<header class="chat-header">
					<div class="chat-person">
						<span class="avatar gradient">GV</span>
						<div>
							<h2 data-course-title>Dang tai cuoc tro chuyen...</h2>
							<p><span class="online-dot"></span> Mentor dang san sang ho tro</p>
						</div>
					</div>
					<div class="chat-actions">
						<button type="button" aria-label="Goi video"><i class="fa-solid fa-video" aria-hidden="true"></i></button>
						<button type="button" aria-label="Thong tin"><i class="fa-solid fa-circle-info" aria-hidden="true"></i></button>
					</div>
				</header>

				<div class="message-list" data-message-list>
					<div class="chat-empty">Dang tai tin nhan...</div>
				</div>

				<form class="message-form" data-message-form data-course-id={courseId}>
					<button type="button" aria-label="Dinh kem"><i class="fa-solid fa-paperclip" aria-hidden="true"></i></button>
					<textarea name="body" rows="1" placeholder="Nhap thac mac cua ban..." required></textarea>
					<button class="send-button" type="submit" aria-label="Gui tin nhan">
						<i class="fa-solid fa-paper-plane" aria-hidden="true"></i>
					</button>
					<p class="form-status" data-message-status></p>
				</form>
			</main>
		</div>

		<aside class="chat-dock" aria-label="Thanh truy cap nhanh tin nhan">
			<button class="dock-button" type="button" aria-label="Tuy chon">
				<i class="fa-solid fa-ellipsis" aria-hidden="true"></i>
			</button>
			<a class="dock-avatar avatar-photo-one" href="/dashboard" aria-label="Cuoc tro chuyen 1"></a>
			<a class="dock-avatar avatar-photo-two" href="/dashboard" aria-label="Cuoc tro chuyen 2"></a>
			<button class="dock-button compose" type="button" aria-label="Soan tin nhan">
				<i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
			</button>
		</aside>
	</section>
</Layout>

<script>
	const form = document.querySelector("[data-message-form]");
	const list = document.querySelector("[data-message-list]");
	const title = document.querySelector("[data-course-title]");
	const sidebarTitle = document.querySelector("[data-sidebar-title]");
	const status = document.querySelector("[data-message-status]");

	type Message = {
		body: string;
		created_at: string;
		sender_name: string;
	};

	type ApiResult = {
		ok?: boolean;
		message?: string;
		course?: { title?: string };
		messages?: Message[];
	};

	function esc(value: string) {
		return value.replace(/[&<>"']/g, (char) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[char] || char);
	}

	function setText(target: Element | null, value: string) {
		if (target instanceof HTMLElement) target.textContent = value;
	}

	function initials(name: string) {
		return name
			.split(" ")
			.filter(Boolean)
			.slice(-2)
			.map((part) => part[0])
			.join("")
			.toUpperCase() || "SV";
	}

	async function loadMessages() {
		if (!(form instanceof HTMLFormElement)) return;
		const courseId = form.dataset.courseId;
		const studentId = new URLSearchParams(window.location.search).get("studentId");
		const query = studentId ? `?studentId=${encodeURIComponent(studentId)}` : "";
		const response = await fetch(`/api/messages/${courseId}${query}`);
		const result = (await response.json()) as ApiResult;

		if (!response.ok || !result.ok) {
			setText(title, "Ban chua co quyen xem cuoc tro chuyen nay");
			if (list instanceof HTMLElement) {
				list.innerHTML = `<div class="chat-empty">${esc(result.message || "Ban can mua khoa hoc truoc khi nhan tin.")}</div>`;
			}
			return;
		}

		const courseTitle = result.course?.title || "Tin nhan khoa hoc";
		setText(title, courseTitle);
		setText(sidebarTitle, courseTitle);

		if (list instanceof HTMLElement) {
			const messages = result.messages || [];
			list.innerHTML = messages.length
				? messages
						.map((message: Message, index: number) => {
							const mine = index % 2 === 1;
							return `
								<article class="message-row ${mine ? "mine" : ""}">
									<span class="message-avatar">${initials(message.sender_name)}</span>
									<div class="bubble">
										<div class="bubble-meta">
											<strong>${esc(message.sender_name)}</strong>
											<small>${new Date(message.created_at).toLocaleString("vi-VN")}</small>
										</div>
										<p>${esc(message.body)}</p>
									</div>
								</article>
							`;
						})
						.join("")
				: `<div class="chat-empty">
					<strong>Chua co tin nhan nao.</strong>
					<p>Hay gui cau hoi dau tien cho mentor cua khoa hoc nay.</p>
				</div>`;
			list.scrollTop = list.scrollHeight;
		}
	}

	if (form instanceof HTMLFormElement) {
		form.addEventListener("submit", async (event) => {
			event.preventDefault();
			const courseId = form.dataset.courseId;
			const payload = Object.fromEntries(new FormData(form)) as Record<string, FormDataEntryValue | string | null>;
			payload.studentPublicId = new URLSearchParams(window.location.search).get("studentId");
			setText(status, "Dang gui...");
			const response = await fetch(`/api/messages/${courseId}`, {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(payload),
			});
			const result = (await response.json()) as ApiResult;
			setText(status, result.message || (response.ok ? "Da gui." : "Khong gui duoc."));
			if (response.ok) {
				form.reset();
				await loadMessages();
			}
		});
	}

	loadMessages().catch(() => undefined);
</script>

<style>
	.messenger-page {
		position: relative;
		padding: 34px 0 18px;
		background:
			linear-gradient(135deg, rgb(37 99 235 / 0.08), transparent 36rem),
			var(--soft);
	}

	.messenger-shell {
		display: grid;
		grid-template-columns: 330px minmax(0, 1fr);
		gap: 22px;
		min-height: calc(100vh - 158px);
		padding-right: 78px;
	}

	.conversation-list,
	.chat-panel {
		overflow: hidden;
		border-radius: 24px;
	}

	.conversation-list {
		display: grid;
		grid-template-rows: auto auto minmax(0, 1fr);
		padding: 18px;
	}

	.conversation-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.conversation-head span {
		color: var(--primary);
		font-size: 0.78rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.conversation-head h1 {
		margin: 2px 0 0;
		font-size: 1.55rem;
		line-height: 1.15;
	}

	.conversation-head button,
	.chat-actions button,
	.message-form button {
		border: 0;
		cursor: pointer;
	}

	.conversation-head button,
	.chat-actions button {
		width: 42px;
		height: 42px;
		display: grid;
		place-items: center;
		border-radius: 999px;
		background: rgb(37 99 235 / 0.1);
		color: var(--primary);
	}

	.conversation-search {
		display: flex;
		align-items: center;
		gap: 10px;
		margin: 18px 0;
		padding: 0 14px;
		min-height: 44px;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: var(--soft);
		color: var(--muted);
	}

	.conversation-search input {
		width: 100%;
		border: 0;
		outline: 0;
		background: transparent;
	}

	.conversation-items {
		display: grid;
		align-content: start;
		gap: 10px;
	}

	.conversation-items button {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 12px;
		border: 1px solid transparent;
		border-radius: 18px;
		background: transparent;
		text-align: left;
		cursor: pointer;
	}

	.conversation-items button.active,
	.conversation-items button:hover {
		border-color: rgb(37 99 235 / 0.14);
		background: rgb(37 99 235 / 0.08);
	}

	.conversation-items strong,
	.conversation-items small {
		display: block;
	}

	.conversation-items small {
		color: var(--muted);
	}

	.avatar {
		width: 48px;
		height: 48px;
		display: grid;
		place-items: center;
		flex: 0 0 auto;
		border-radius: 999px;
		color: #fff;
		font-weight: 900;
	}

	.avatar.gradient,
	.message-avatar {
		background: linear-gradient(135deg, var(--primary), var(--secondary));
	}

	.avatar.image-one {
		background:
			linear-gradient(rgb(37 99 235 / 0.08), rgb(37 99 235 / 0.08)),
			url("https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=160&q=80") center / cover;
	}

	.chat-panel {
		display: grid;
		grid-template-rows: auto minmax(0, 1fr) auto;
		background: #fff;
	}

	.chat-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding: 18px 20px;
		border-bottom: 1px solid var(--line);
	}

	.chat-person {
		display: flex;
		align-items: center;
		gap: 12px;
		min-width: 0;
	}

	.chat-person h2 {
		margin: 0;
		font-size: 1.18rem;
		line-height: 1.25;
	}

	.chat-person p {
		display: flex;
		align-items: center;
		gap: 7px;
		margin: 4px 0 0;
		color: var(--muted);
		font-size: 0.9rem;
	}

	.online-dot {
		width: 9px;
		height: 9px;
		border-radius: 999px;
		background: var(--success);
	}

	.chat-actions {
		display: flex;
		gap: 8px;
	}

	.message-list {
		overflow: auto;
		display: grid;
		align-content: end;
		gap: 14px;
		padding: 22px;
		background:
			radial-gradient(circle at 12% 10%, rgb(96 165 250 / 0.12), transparent 18rem),
			#f8fafc;
	}

	.message-row {
		display: flex;
		align-items: end;
		gap: 10px;
		max-width: 78%;
	}

	.message-row.mine {
		justify-self: end;
		flex-direction: row-reverse;
	}

	.message-avatar {
		width: 34px;
		height: 34px;
		display: grid;
		place-items: center;
		flex: 0 0 auto;
		border-radius: 999px;
		color: #fff;
		font-size: 0.72rem;
		font-weight: 900;
	}

	.bubble {
		padding: 12px 14px;
		border: 1px solid var(--line);
		border-radius: 18px 18px 18px 6px;
		background: #fff;
		box-shadow: var(--shadow-sm);
	}

	.message-row.mine .bubble {
		border-color: rgb(37 99 235 / 0.16);
		border-radius: 18px 18px 6px 18px;
		background: linear-gradient(135deg, var(--primary), var(--secondary));
		color: #fff;
	}

	.bubble-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 5px;
	}

	.bubble-meta small {
		color: var(--muted);
		font-size: 0.74rem;
		white-space: nowrap;
	}

	.message-row.mine .bubble-meta small {
		color: rgb(255 255 255 / 0.75);
	}

	.bubble p {
		margin: 0;
	}

	.chat-empty {
		margin: auto;
		padding: 24px;
		border: 1px dashed rgb(148 163 184 / 0.4);
		border-radius: 20px;
		background: rgb(255 255 255 / 0.8);
		color: var(--muted);
		text-align: center;
	}

	.message-form {
		position: relative;
		display: grid;
		grid-template-columns: 44px minmax(0, 1fr) 46px;
		gap: 10px;
		align-items: end;
		padding: 16px;
		border-top: 1px solid var(--line);
		background: #fff;
	}

	.message-form textarea {
		width: 100%;
		max-height: 120px;
		resize: vertical;
		border: 1px solid var(--line);
		border-radius: 18px;
		padding: 12px 14px;
		outline: none;
	}

	.message-form > button {
		width: 44px;
		height: 44px;
		display: grid;
		place-items: center;
		border-radius: 999px;
		background: rgb(37 99 235 / 0.08);
		color: var(--primary);
	}

	.message-form .send-button {
		width: 46px;
		height: 46px;
		background: var(--primary);
		color: #fff;
		box-shadow: var(--shadow-blue);
	}

	.message-form .form-status {
		grid-column: 1 / -1;
		margin: 0;
		min-height: 18px;
		color: var(--muted);
		font-size: 0.86rem;
	}

	.chat-dock {
		position: fixed;
		top: 92px;
		right: 0;
		z-index: 45;
		width: 82px;
		min-height: 360px;
		display: grid;
		align-content: center;
		justify-items: center;
		gap: 14px;
		padding: 18px 10px;
		border-left: 1px solid rgb(255 255 255 / 0.06);
		background: #1f1f1f;
		box-shadow: -12px 0 34px rgb(15 23 42 / 0.18);
	}

	.dock-button,
	.dock-avatar {
		width: 54px;
		height: 54px;
		display: grid;
		place-items: center;
		border: 0;
		border-radius: 999px;
		background: #4b4b4f;
		color: #fff;
		text-decoration: none;
		cursor: pointer;
		box-shadow: 0 8px 18px rgb(0 0 0 / 0.22);
		transition: transform 300ms ease, background 300ms ease;
	}

	.dock-button:hover,
	.dock-avatar:hover {
		transform: translateY(-2px) scale(1.03);
		background: #5b5b61;
	}

	.dock-button i {
		font-size: 1.25rem;
	}

	.dock-button.compose {
		background: #505154;
	}

	.dock-avatar {
		border: 2px solid #2b2b2b;
		background-size: cover;
		background-position: center;
	}

	.avatar-photo-one {
		background-image: url("https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=160&q=80");
	}

	.avatar-photo-two {
		background-image: url("https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=160&q=80");
	}

	@media (max-width: 1080px) {
		.messenger-shell {
			grid-template-columns: 1fr;
			padding-right: 72px;
		}

		.conversation-list {
			display: none;
		}
	}

	@media (max-width: 720px) {
		.messenger-page {
			padding-top: 14px;
		}

		.messenger-shell {
			width: min(100% - 18px, 1180px);
			min-height: calc(100vh - 128px);
			padding-right: 56px;
		}

		.chat-dock {
			top: 70px;
			width: 58px;
			min-height: 318px;
			gap: 11px;
			padding: 12px 6px;
		}

		.dock-button,
		.dock-avatar {
			width: 44px;
			height: 44px;
		}

		.chat-header {
			padding: 14px;
		}

		.chat-actions {
			display: none;
		}

		.message-list {
			padding: 14px;
		}

		.message-row {
			max-width: 94%;
		}

		.message-form {
			grid-template-columns: minmax(0, 1fr) 44px;
		}

		.message-form > button:first-child {
			display: none;
		}
	}
</style>
