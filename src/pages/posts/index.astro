---
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";
import Layout from "../../layouts/Layout.astro";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	status: "published",
	orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);

const formatDate = (date?: Date | null) =>
	date
		? new Intl.DateTimeFormat("vi-VN", {
				day: "2-digit",
				month: "2-digit",
				year: "numeric",
			}).format(date)
		: "Chua co ngay";
---

<Layout>
  <section class="page-header">
    <div class="container">
      <h1>Blog & Tin tuc</h1>
      <p class="section-subhead">
        Cap nhat kien thuc, xu huong cong nghe moi nhat
      </p>
    </div>
  </section>

  <section class="blog-list">
    <div class="container">
      {
        posts.length === 0 ? (
          <p class="text-center">
            Chua co bai viet nao. Hay tao bai viet trong EmDash Admin.
          </p>
        ) : (
          <div class="grid-auto">
            {posts.map((post) => (
              <a href={`/posts/${post.id}`} class="card blog-card">
                {post.data.featured_image && (
                  <div class="blog-image" {...post.edit.featured_image}>
                    <Image image={post.data.featured_image} />
                  </div>
                )}
                <div class="blog-date">{formatDate(post.data.publishedAt)}</div>
                <h3 {...post.edit.title}>{post.data.title}</h3>
                {post.data.excerpt && <p {...post.edit.excerpt}>{post.data.excerpt}</p>}
                <div class="read-more">Doc tiep</div>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Layout>

<style is:global>
  .blog-list {
    padding: 60px 0;
  }
  .blog-card {
    display: block;
    text-decoration: none;
  }
  .blog-image {
    margin-bottom: 16px;
    overflow: hidden;
    border-radius: 8px;
  }
  .blog-date {
    font-size: 0.85rem;
    color: var(--primary-blue);
    margin-bottom: 12px;
  }
  .read-more {
    margin-top: 16px;
    font-weight: 600;
    color: var(--primary-blue);
  }
  .text-center {
    text-align: center;
    padding: 40px;
  }
</style>
