---
import { decodeSlug, getEmDashEntry, getEntryTerms } from "emdash";
import { Image, PortableText } from "emdash/ui";
import Layout from "../../layouts/Layout.astro";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
  return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
  return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

const [categories, tags] = await Promise.all([
  getEntryTerms("posts", post.data.id, "category"),
  getEntryTerms("posts", post.data.id, "tag"),
]);

const formattedDate = post.data.publishedAt
  ? new Intl.DateTimeFormat("vi-VN", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
    }).format(post.data.publishedAt)
  : "Chua co ngay";
---

<Layout>
  <article class="post-container">
    <div class="container">
      <div class="post-header">
        {post.data.featured_image && (
          <div class="post-image" {...post.edit.featured_image}>
            <Image image={post.data.featured_image} />
          </div>
        )}
        <h1 {...post.edit.title}>{post.data.title}</h1>
        <div class="post-meta">
          <time datetime={post.data.publishedAt?.toISOString()}>{formattedDate}</time>
          {
            categories.map((category) => (
              <a href={`/category/${category.slug}`} class="post-category">
                {category.label}
              </a>
            ))
          }
          <div class="post-tags">
            {tags.map((tag) => <a href={`/tag/${tag.slug}`} class="tag">#{tag.label}</a>)}
          </div>
        </div>
      </div>
      <div class="post-content" {...post.edit.content}>
        <PortableText value={post.data.content ?? []} />
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  .post-container {
    padding: 60px 0;
    max-width: 800px;
    margin: 0 auto;
  }
  .post-image {
    margin-bottom: 28px;
    overflow: hidden;
    border-radius: 8px;
  }
  .post-header {
    margin-bottom: 2rem;
  }
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    color: var(--text-muted);
    margin: 1rem 0;
  }
  .post-category,
  .tag {
    background: var(--border-color);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    color: inherit;
    text-decoration: none;
  }
  .post-content {
    line-height: 1.8;
  }
  .post-content h2 {
    text-align: left;
    margin: 2rem 0 1rem;
  }
  .post-content h2:after {
    margin-left: 0;
  }
</style>
