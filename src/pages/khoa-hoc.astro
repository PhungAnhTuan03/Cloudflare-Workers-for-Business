---
import Layout from "../layouts/Layout.astro";
import { courseCategories, courses, site } from "../lib/site-data";

const selectedField = Astro.url.searchParams.get("field") ?? "all";
const visibleCourses =
	selectedField === "all"
		? courses
		: courses.filter((course) => course.categoryId === selectedField);
---

<Layout
	title={`Khóa học công nghệ - ${site.name}`}
	description="Danh sách khóa học tin học văn phòng, AI, lập trình, thiết kế đồ họa, AutoCAD và Digital Marketing. Học thực chiến, mentor theo sát, có dự án cuối khóa."
>
	<section class="page-hero">
		<div class="container page-hero-grid">
			<div>
				<p class="page-kicker"><i class="fa-solid fa-layer-group"></i> Danh mục khóa học</p>
				<h1 class="page-title">Khóa học công nghệ cho từng mục tiêu nghề nghiệp.</h1>
				<p class="page-lead">
					Chọn khóa học theo năng lực hiện tại, lịch học và outcome mong muốn. Mỗi khóa đều có
					lộ trình, mentor, bài tập thực tế và chứng nhận hoàn thành.
				</p>
			</div>
			<div class="hero-summary card">
				<strong>{courses.length}</strong>
				<span>khóa học đang mở lớp</span>
				<p>Khai giảng linh hoạt hằng tuần, có lớp online, offline và đào tạo theo nhóm doanh nghiệp.</p>
			</div>
		</div>
	</section>

	<section class="section tight">
		<div class="container">
			<div class="filter-bar" aria-label="Lọc khóa học">
				<a class:list={["filter-chip", selectedField === "all" && "is-active"]} href="/khoa-hoc">
					Tất cả
				</a>
				{courseCategories.map((category) => (
					<a
						class:list={["filter-chip", selectedField === category.id && "is-active"]}
						href={`/khoa-hoc?field=${category.id}`}
					>
						<i class={category.icon}></i>
						{category.title}
					</a>
				))}
			</div>

			<div class="course-list-grid">
				{visibleCourses.map((course) => {
					const category = courseCategories.find((item) => item.id === course.categoryId);
					return (
						<a href={`/khoa-hoc/${course.slug}`} class="course-list-card">
							<img src={course.image} alt={course.title} loading="lazy" />
							<div class="course-list-content">
								<div class="course-tags">
									<span>{category?.title}</span>
									<span><i class="fa-solid fa-star"></i> {course.rating}</span>
								</div>
								<h2>{course.title}</h2>
								<p>{course.description}</p>
								<div class="course-facts">
									<span><i class="fa-regular fa-clock"></i> {course.duration}</span>
									<span><i class="fa-solid fa-users"></i> {course.students}</span>
									<span><i class="fa-solid fa-signal"></i> {course.level}</span>
								</div>
								<div class="course-action">
									<strong>{course.price}</strong>
									<span class="btn btn-primary">Xem chi tiết</span>
								</div>
							</div>
						</a>
					);
				})}
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero-summary {
		padding: 26px;
	}

	.hero-summary strong,
	.hero-summary span {
		display: block;
	}

	.hero-summary strong {
		color: var(--primary);
		font-size: 4rem;
		line-height: 1;
	}

	.hero-summary span {
		margin-top: 8px;
		font-size: 1.2rem;
		font-weight: 900;
	}

	.hero-summary p {
		color: var(--muted);
	}

	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-bottom: 28px;
	}

	.filter-chip {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 10px 13px;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: #fff;
		color: #334155;
		font-weight: 800;
		text-decoration: none;
	}

	.filter-chip:hover,
	.filter-chip.is-active {
		border-color: rgb(37 99 235 / 0.3);
		background: rgb(37 99 235 / 0.08);
		color: var(--primary);
	}

	.course-list-grid {
		display: grid;
		gap: 20px;
	}

	.course-list-card {
		display: grid;
		grid-template-columns: 320px minmax(0, 1fr);
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		color: inherit;
		text-decoration: none;
		box-shadow: var(--shadow-sm);
		transition: transform 180ms ease, box-shadow 180ms ease;
	}

	.course-list-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
	}

	.course-list-card img {
		width: 100%;
		height: 100%;
		min-height: 260px;
		object-fit: cover;
	}

	.course-list-content {
		padding: 24px;
	}

	.course-list-content h2 {
		margin: 14px 0 8px;
		font-size: clamp(1.5rem, 3vw, 2rem);
		line-height: 1.15;
	}

	.course-list-content p {
		color: var(--muted);
	}

	.course-tags,
	.course-facts,
	.course-action {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 10px;
	}

	.course-tags span,
	.course-facts span {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		color: var(--muted);
		font-size: 0.9rem;
		font-weight: 800;
	}

	.course-tags span:first-child {
		color: var(--primary);
	}

	.course-tags i {
		color: var(--accent);
	}

	.course-action {
		justify-content: space-between;
		margin-top: 22px;
	}

	.course-action strong {
		color: var(--primary);
		font-size: 1.45rem;
	}

	@media (max-width: 760px) {
		.course-list-card {
			grid-template-columns: 1fr;
		}

		.course-list-card img {
			min-height: 220px;
			aspect-ratio: 16 / 9;
		}
	}
</style>
