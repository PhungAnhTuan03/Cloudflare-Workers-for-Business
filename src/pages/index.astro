---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="hero">
    <div class="container">
      <h1>Nâng tầm kỹ năng <span style="color:#F1C40F">Công nghệ</span></h1>
      <p class="hero-sub">Hơn 10.000 học viên thành công</p>
      <div class="hero-buttons">
        <a href="/khoa-hoc" class="btn btn-primary">Khám phá khóa học</a>
        <a href="/dang-ky" class="btn btn-cta">Đăng ký ngay</a>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2>Khóa học nổi bật</h2>
      <div class="grid-auto">
        <!-- Các thẻ card .card -->
        <div class="card lazy">
          <i class="fas fa-file-excel fa-3x" style="color: var(--primary-blue)"></i>
          <h3>Tin học văn phòng</h3>
          <p>Word, Excel, PowerPoint chuyên sâu</p>
          <a href="#" class="btn btn-primary" style="margin-top: 1rem;">Chi tiết</a>
        </div>
        <!-- Thêm card khác tương tự -->
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .hero {
    background: linear-gradient(120deg, var(--primary-dark) 0%, #1a3b4e 100%);
    color: white;
    text-align: center;
    padding: 100px 0;
  }
  .hero-sub {
    font-size: 1.2rem;
    max-width: 700px;
    margin: 0 auto;
    opacity: 0.9;
  }
  .hero-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
</style>