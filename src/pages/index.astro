---
import Layout from "../layouts/Layout.astro";
import {
	articles,
	courseCategories,
	courses,
	instructors,
	reasons,
	roadmap,
	site,
	stats,
	testimonials,
} from "../lib/site-data";

const featuredCourses = courses.slice(0, 4);
const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "EducationalOrganization",
	name: site.name,
	url: Astro.url.origin,
	email: site.email,
	telephone: site.phone,
	address: {
		"@type": "PostalAddress",
		streetAddress: site.address,
		addressCountry: "VN",
	},
};
---

<Layout
	title={`${site.name} - Trung tâm đào tạo công nghệ thực chiến`}
	description="Học tin học văn phòng, AI, lập trình, thiết kế đồ họa, AutoCAD và Digital Marketing với mentor thực chiến, dự án thật và lộ trình rõ ràng."
	schema={organizationSchema}
>
	<section class="home-hero">
		<div class="container hero-grid">
			<div class="hero-copy">
				<p class="page-kicker"><i class="fa-solid fa-bolt"></i> Học để làm được việc thật</p>
				<h1 class="page-title">
					Nâng cấp kỹ năng công nghệ với lộ trình rõ ràng và mentor theo sát.
				</h1>
				<p class="page-lead">
					Sao Việt Tech Academy đào tạo thực chiến cho người đi làm, sinh viên và
					doanh nghiệp: học nhanh, làm dự án thật, có sản phẩm để chứng minh năng lực.
				</p>
				<div class="hero-actions">
					<a href="/dang-ky-tu-van" class="btn btn-primary">
						<i class="fa-solid fa-paper-plane"></i>
						Đăng ký học
					</a>
					<a href="/khoa-hoc" class="btn btn-secondary">
						<i class="fa-solid fa-layer-group"></i>
						Xem khóa học
					</a>
				</div>
				<div class="hero-trust">
					<span><i class="fa-solid fa-circle-check"></i> Khai giảng hằng tuần</span>
					<span><i class="fa-solid fa-circle-check"></i> Học online hoặc offline</span>
					<span><i class="fa-solid fa-circle-check"></i> Có chứng nhận hoàn thành</span>
				</div>
			</div>

			<div class="hero-media" aria-label="Học viên trong lớp đào tạo công nghệ">
				<img
					src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=1200&q=82"
					alt="Nhóm học viên đang học công nghệ cùng giảng viên"
					loading="eager"
				/>
				<div class="hero-floating-card">
					<strong>92%</strong>
					<span>học viên hoàn thành mục tiêu sau khóa học</span>
				</div>
			</div>
		</div>
	</section>

	<section class="stats-band">
		<div class="container stats-grid">
			{stats.map((item) => (
				<div class="stat-card">
					<strong>{item.value}</strong>
					<span>{item.label}</span>
				</div>
			))}
		</div>
	</section>

	<section id="gioi-thieu" class="section about-home-section">
		<div class="container about-home-grid">
			<div class="about-home-media">
				<img
					src="https://images.unsplash.com/photo-1571260899304-425eee4c7efc?auto=format&fit=crop&w=1200&q=82"
					alt="Lop hoc cong nghe hien dai tai Sao Viet Tech Academy"
					loading="lazy"
				/>
			</div>
			<div class="about-home-copy">
				<p class="section-eyebrow">Ve Sao Viet Tech Academy</p>
				<h2 class="section-title">Mot moi truong hoc cong nghe gon, thuc te va co dinh huong.</h2>
				<p class="section-lead">
					Chung toi xay chuong trinh dao tao cho nguoi can dung ky nang ngay trong cong viec:
					tu tin hoc van phong, AI, lap trinh den thiet ke va marketing so.
				</p>
				<div class="about-points">
					<div>
						<i class="fa-solid fa-laptop-code" aria-hidden="true"></i>
						<strong>Hoc bang du an that</strong>
						<span>Moi module deu co bai tap va san pham dau ra ro rang.</span>
					</div>
					<div>
						<i class="fa-solid fa-user-check" aria-hidden="true"></i>
						<strong>Mentor theo sat</strong>
						<span>Giang vien review bai, sua loi va goi y lo trinh tiep theo.</span>
					</div>
				</div>
				<a href="/dang-ky-tu-van" class="btn btn-primary">Nhan tu van lo trinh</a>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-head">
				<div>
					<p class="section-eyebrow">Danh mục đào tạo</p>
					<h2 class="section-title">Chọn đúng kỹ năng cho mục tiêu tiếp theo.</h2>
				</div>
				<a href="/khoa-hoc" class="btn btn-ghost">Tất cả khóa học</a>
			</div>
			<div class="category-grid">
				{courseCategories.map((category) => (
					<a href={category.href} class="category-card">
						<div class="category-icon" style={`--accent-color: ${category.accent}`}>
							<i class={category.icon}></i>
						</div>
						<h3>{category.title}</h3>
						<p>{category.description}</p>
						<span>Xem chi tiết <i class="fa-solid fa-arrow-right"></i></span>
					</a>
				))}
			</div>
		</div>
	</section>

	<section class="section featured-section">
		<div class="container">
			<div class="section-head center">
				<p class="section-eyebrow">Khóa học nổi bật</p>
				<h2 class="section-title">Các chương trình đang được học viên chọn nhiều.</h2>
				<p class="section-lead">
					Mỗi khóa được thiết kế theo outcome rõ ràng, có bài tập, mentor review và sản phẩm cuối khóa.
				</p>
			</div>
			<div class="course-grid">
				{featuredCourses.map((course) => (
					<a href={`/khoa-hoc/${course.slug}`} class="course-card">
						<img src={course.image} alt={course.title} loading="lazy" />
						<div class="course-body">
							<div class="course-meta">
								<span><i class="fa-solid fa-star"></i> {course.rating}</span>
								<span>{course.students} học viên</span>
							</div>
							<h3>{course.title}</h3>
							<p>{course.description}</p>
							<div class="course-bottom">
								<strong>{course.price}</strong>
								<span>{course.duration}</span>
							</div>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<section class="section why-section">
		<div class="container why-grid">
			<div>
				<p class="section-eyebrow">Tại sao chọn chúng tôi</p>
				<h2 class="section-title">Không học lan man. Mỗi buổi đều tiến gần hơn tới kỹ năng thật.</h2>
				<p class="section-lead">
					Chúng tôi ưu tiên thực hành, phản hồi cá nhân và đầu ra đo được thay vì chỉ hoàn thành giáo trình.
				</p>
			</div>
			<div class="reason-grid">
				{reasons.map((reason) => (
					<div class="reason-card">
						<i class={reason.icon}></i>
						<h3>{reason.title}</h3>
						<p>{reason.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-head center">
				<p class="section-eyebrow">Lộ trình học</p>
				<h2 class="section-title">Từ tư vấn đến portfolio trong một quy trình gọn gàng.</h2>
			</div>
			<div class="timeline">
				{roadmap.map((item) => (
					<div class="timeline-item">
						<span>{item.step}</span>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="section testimonial-section">
		<div id="giang-vien" class="container instructor-home-block">
			<div class="section-head">
				<div>
					<p class="section-eyebrow">Doi ngu giang vien</p>
					<h2 class="section-title">Hoc cung mentor co kinh nghiem trien khai thuc te.</h2>
					<p class="section-lead">
						Giang vien huong dan quy trinh lam viec, review san pham va giup hoc vien hieu tieu chuan dau ra trong moi truong doanh nghiep.
					</p>
				</div>
				<a href="/dang-ky-tu-van" class="btn btn-secondary">Gap mentor tu van</a>
			</div>
			<div class="instructor-home-grid">
				{instructors.map((instructor) => (
					<article class="instructor-home-card">
						<img src={instructor.image} alt={instructor.name} loading="lazy" />
						<div>
							<span>{instructor.experience}</span>
							<h3>{instructor.name}</h3>
							<p class="mentor-role">{instructor.role}</p>
							<p>{instructor.bio}</p>
							<div class="mentor-skills">
								{instructor.skills.map((skill) => <small>{skill}</small>)}
							</div>
						</div>
					</article>
				))}
			</div>
		</div>

		<div class="container">
			<div class="section-head">
				<div>
					<p class="section-eyebrow">Feedback học viên</p>
					<h2 class="section-title">Những câu chuyện học xong dùng được ngay.</h2>
				</div>
				<a href="/hoc-vien" class="btn btn-secondary">Xem thêm đánh giá</a>
			</div>
			<div class="testimonial-track">
				{testimonials.map((item) => (
					<figure class="testimonial-card">
						<div class="rating"><i class="fa-solid fa-star"></i> {item.rating}</div>
						<blockquote>{item.content}</blockquote>
						<figcaption>
							<strong>{item.name}</strong>
							<span>{item.role}</span>
						</figcaption>
					</figure>
				))}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-head">
				<div>
					<p class="section-eyebrow">Tin tức & hướng dẫn</p>
					<h2 class="section-title">Cập nhật xu hướng học tập và công nghệ.</h2>
				</div>
				<a href="/tin-tuc" class="btn btn-ghost">Tất cả bài viết</a>
			</div>
			<div class="article-grid">
				{articles.map((article) => (
					<a href="/tin-tuc" class="article-card">
						<img src={article.image} alt={article.title} loading="lazy" />
						<div>
							<span>{article.category} · {article.date}</span>
							<h3>{article.title}</h3>
							<p>{article.description}</p>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<section class="section consult-section" id="tu-van">
		<div class="container consult-grid">
			<div>
				<p class="section-eyebrow">Đăng ký tư vấn</p>
				<h2 class="section-title">Chưa biết nên bắt đầu từ đâu? Để mentor gợi ý lộ trình.</h2>
				<p class="section-lead">
					Gửi thông tin, đội ngũ tư vấn sẽ liên hệ để đề xuất khóa học phù hợp với mục tiêu và lịch học của bạn.
				</p>
			</div>
			<form class="lead-form card" action="/api/contact" method="POST" data-contact-form>
				<div class="form-honeypot" aria-hidden="true">
					<label for="home-website">Website</label>
					<input id="home-website" name="website" tabindex="-1" autocomplete="off" />
				</div>
				<div class="form-grid">
					<div class="field">
						<label for="home-name">Họ tên</label>
						<input id="home-name" name="name" autocomplete="name" required />
					</div>
					<div class="field">
						<label for="home-phone">Số điện thoại</label>
						<input id="home-phone" name="phone" autocomplete="tel" required />
					</div>
					<div class="field">
						<label for="home-email">Email</label>
						<input id="home-email" type="email" name="email" autocomplete="email" required />
					</div>
					<div class="field">
						<label for="home-course">Khóa học quan tâm</label>
						<select id="home-course" name="subject">
							{courses.map((course) => <option value={course.title}>{course.title}</option>)}
						</select>
					</div>
					<div class="field full">
						<label for="home-message">Mục tiêu học tập</label>
						<textarea id="home-message" name="message" rows="4" required>Muốn được tư vấn lộ trình học phù hợp.</textarea>
					</div>
				</div>
				<button type="submit" class="btn btn-primary">Gửi thông tin tư vấn</button>
				<p class="form-status" aria-live="polite"></p>
			</form>
		</div>
	</section>
</Layout>

<script>
	document.querySelectorAll("[data-contact-form]").forEach((formElement) => {
		if (!(formElement instanceof HTMLFormElement)) return;
		const status = formElement.querySelector(".form-status");

		formElement.addEventListener("submit", async (event) => {
			event.preventDefault();
			const button = formElement.querySelector("button[type='submit']");
			if (button instanceof HTMLButtonElement) button.disabled = true;
			if (status instanceof HTMLElement) {
				status.dataset.state = "";
				status.textContent = "Đang gửi thông tin...";
			}

			try {
				const body = new URLSearchParams();
				for (const [key, value] of new FormData(formElement).entries()) {
					if (typeof value === "string") body.append(key, value);
				}
				const response = await fetch("/api/contact", {
					method: "POST",
					body,
					headers: { "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8" },
				});
				const result = (await response.json().catch(() => ({}))) as { message?: string };
				if (!response.ok) throw new Error(result.message || "Không gửi được thông tin.");
				if (status instanceof HTMLElement) {
					status.dataset.state = "success";
					status.textContent = result.message || "Gửi thành công. Chúng tôi sẽ liên hệ lại sớm.";
				}
				formElement.reset();
			} catch (error) {
				if (status instanceof HTMLElement) {
					status.dataset.state = "error";
					status.textContent = error instanceof Error ? error.message : "Lỗi kết nối, vui lòng thử lại.";
				}
			} finally {
				if (button instanceof HTMLButtonElement) button.disabled = false;
			}
		});
	});
</script>

<style>
	.home-hero {
		padding: 86px 0 64px;
		overflow: hidden;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
		gap: 48px;
		align-items: center;
	}

	.hero-actions,
	.hero-trust {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 26px;
	}

	.hero-trust {
		color: var(--muted);
		font-size: 0.92rem;
		font-weight: 700;
	}

	.hero-trust i {
		color: var(--success);
	}

	.hero-media {
		position: relative;
		border-radius: 8px;
		overflow: hidden;
		box-shadow: var(--shadow-md);
		aspect-ratio: 5 / 4;
		max-height: 560px;
	}

	.hero-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.hero-floating-card {
		position: absolute;
		right: 18px;
		bottom: 18px;
		width: min(230px, calc(100% - 36px));
		padding: 16px;
		border: 1px solid rgb(255 255 255 / 0.5);
		border-radius: 8px;
		background: rgb(255 255 255 / 0.92);
		box-shadow: var(--shadow-sm);
	}

	.hero-floating-card strong {
		display: block;
		color: var(--primary);
		font-size: 2rem;
		line-height: 1;
	}

	.hero-floating-card span {
		color: var(--muted);
		font-size: 0.92rem;
		font-weight: 700;
	}

	.stats-band {
		padding: 28px 0;
		border-block: 1px solid rgb(37 99 235 / 0.08);
		background:
			linear-gradient(135deg, rgb(37 99 235 / 0.08), rgb(96 165 250 / 0.16)),
			#f8fafc;
		color: var(--ink);
	}

	.about-home-section {
		background: #fff;
	}

	.about-home-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
		gap: 46px;
		align-items: center;
	}

	.about-home-media {
		overflow: hidden;
		border-radius: 24px;
		box-shadow: var(--shadow-md);
		aspect-ratio: 4 / 3;
		background: var(--surface-2);
	}

	.about-home-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.about-home-copy {
		min-width: 0;
	}

	.about-points {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
		margin: 24px 0;
	}

	.about-points div {
		display: grid;
		gap: 6px;
		padding: 18px;
		border: 1px solid var(--line);
		border-radius: 18px;
		background: var(--soft);
	}

	.about-points i {
		color: var(--primary);
		font-size: 1.4rem;
	}

	.about-points span {
		color: var(--muted);
		font-size: 0.92rem;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 14px;
	}

	.stat-card {
		padding: 18px;
		border: 1px solid rgb(37 99 235 / 0.12);
		border-radius: 18px;
		background: rgb(255 255 255 / 0.86);
		box-shadow: var(--shadow-sm);
	}

	.stat-card strong,
	.stat-card span {
		display: block;
	}

	.stat-card strong {
		color: var(--primary);
		font-size: clamp(1.8rem, 4vw, 2.8rem);
		line-height: 1;
	}

	.stat-card span {
		margin-top: 8px;
		color: var(--muted);
		font-weight: 700;
	}

	.category-grid,
	.course-grid,
	.article-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 22px;
	}

	.category-card {
		padding: 24px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		text-decoration: none;
		box-shadow: var(--shadow-sm);
	}

	.category-card:hover,
	.course-card:hover,
	.article-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-md);
	}

	.category-icon {
		width: 52px;
		height: 52px;
		display: grid;
		place-items: center;
		border-radius: 8px;
		background: color-mix(in srgb, var(--accent-color) 12%, white);
		color: var(--accent-color);
	}

	.category-card h3,
	.reason-card h3 {
		margin: 18px 0 8px;
	}

	.category-card p,
	.reason-card p,
	.article-card p,
	.course-card p {
		color: var(--muted);
	}

	.category-card span {
		color: var(--primary);
		font-weight: 800;
	}

	.featured-section,
	.why-section,
	.testimonial-section,
	.consult-section {
		background: var(--surface-2);
	}

	.course-card,
	.article-card {
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		color: inherit;
		text-decoration: none;
		box-shadow: var(--shadow-sm);
		transition: transform 180ms ease, box-shadow 180ms ease;
	}

	.instructor-home-block {
		margin-bottom: 72px;
	}

	.instructor-home-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 22px;
	}

	.instructor-home-card {
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 20px;
		background: #fff;
		box-shadow: var(--shadow-sm);
		transition: transform 300ms ease, box-shadow 300ms ease, border-color 300ms ease;
	}

	.instructor-home-card:hover {
		transform: translateY(-4px);
		border-color: rgb(37 99 235 / 0.18);
		box-shadow: var(--shadow-md);
	}

	.instructor-home-card img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		object-position: center;
		background: var(--surface-2);
	}

	.instructor-home-card > div {
		padding: 20px;
	}

	.instructor-home-card span {
		color: var(--primary);
		font-size: 0.82rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.instructor-home-card h3 {
		margin: 8px 0 4px;
		font-size: 1.35rem;
	}

	.instructor-home-card p {
		color: var(--muted);
	}

	.mentor-role {
		margin-top: 0;
		font-weight: 800;
		color: #334155 !important;
