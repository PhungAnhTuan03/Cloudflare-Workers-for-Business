---
import Layout from "../layouts/Layout.astro";
import { instructors, reasons, site, stats } from "../lib/site-data";
---

<Layout
	title={`Giới thiệu - ${site.name}`}
	description="Sao Việt Tech Academy là trung tâm đào tạo công nghệ thực chiến, tập trung vào kỹ năng số, dự án thật và mentor theo sát."
>
	<section class="page-hero">
		<div class="container page-hero-grid">
			<div>
				<p class="page-kicker"><i class="fa-solid fa-building-columns"></i> Về trung tâm</p>
				<h1 class="page-title">Một môi trường học công nghệ gọn, thực tế và có định hướng.</h1>
				<p class="page-lead">
					Chúng tôi xây chương trình đào tạo cho người cần dùng kỹ năng ngay trong công việc:
					từ tin học văn phòng, AI, lập trình đến thiết kế và marketing số.
				</p>
			</div>
			<img
				class="about-hero-image"
				src="https://images.unsplash.com/photo-1571260899304-425eee4c7efc?auto=format&fit=crop&w=1200&q=82"
				alt="Lớp học công nghệ hiện đại"
				loading="eager"
			/>
		</div>
	</section>

	<section class="section">
		<div class="container story-grid">
			<div>
				<p class="section-eyebrow">Câu chuyện</p>
				<h2 class="section-title">Từ lớp học kỹ năng nhỏ đến hệ sinh thái đào tạo thực chiến.</h2>
			</div>
			<div class="story-copy">
				<p>
					Sao Việt Tech Academy được thiết kế cho những người không muốn học lan man.
					Mỗi khóa học bắt đầu bằng mục tiêu cụ thể, chia thành module thực hành và kết thúc
					bằng sản phẩm có thể đưa vào CV hoặc dùng trong công việc.
				</p>
				<p>
					Điểm khác biệt nằm ở cách mentor phản hồi bài tập: học viên không chỉ biết công cụ,
					mà còn hiểu quy trình làm việc, tiêu chuẩn bàn giao và cách tự học tiếp sau khóa.
				</p>
			</div>
		</div>
	</section>

	<section class="section stats-section">
		<div class="container stats-grid">
			{stats.map((item) => (
				<div class="stat-card">
					<strong>{item.value}</strong>
					<span>{item.label}</span>
				</div>
			))}
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-head center">
				<p class="section-eyebrow">Giá trị vận hành</p>
				<h2 class="section-title">Chúng tôi thiết kế khóa học quanh năng lực thật.</h2>
			</div>
			<div class="value-grid">
				{reasons.map((item) => (
					<div class="value-card">
						<i class={item.icon}></i>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="section instructor-preview">
		<div class="container">
			<div class="section-head">
				<div>
					<p class="section-eyebrow">Đội ngũ</p>
					<h2 class="section-title">Mentor có kinh nghiệm triển khai thực tế.</h2>
				</div>
				<a href="/giang-vien" class="btn btn-secondary">Xem giảng viên</a>
			</div>
			<div class="instructor-grid">
				{instructors.map((instructor) => (
					<article class="instructor-card">
						<img src={instructor.image} alt={instructor.name} loading="lazy" />
						<div>
							<h3>{instructor.name}</h3>
							<p>{instructor.role}</p>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>
</Layout>

<style>
	.about-hero-image {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border-radius: 8px;
		box-shadow: var(--shadow-md);
	}

	.story-grid {
		display: grid;
		grid-template-columns: 0.9fr 1.1fr;
		gap: 42px;
	}

	.story-copy {
		color: var(--muted);
		font-size: 1.06rem;
	}

	.stats-section,
	.instructor-preview {
		background: var(--surface-2);
	}

	.stats-grid,
	.value-grid,
	.instructor-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 18px;
	}

	.stat-card,
	.value-card,
	.instructor-card {
		padding: 22px;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		box-shadow: var(--shadow-sm);
	}

	.stat-card strong {
		display: block;
		color: var(--primary);
		font-size: 2.4rem;
		line-height: 1;
	}

	.stat-card span,
	.value-card p,
	.instructor-card p {
		color: var(--muted);
	}

	.value-grid,
	.instructor-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.value-card i {
		color: var(--primary);
		font-size: 1.8rem;
	}

	.instructor-card {
		overflow: hidden;
		padding: 0;
	}

	.instructor-card img {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
	}

	.instructor-card div {
		padding: 18px;
	}

	@media (max-width: 860px) {
		.story-grid,
		.stats-grid,
		.value-grid,
		.instructor-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
