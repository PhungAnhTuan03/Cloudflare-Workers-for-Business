---
// src/pages/hoc-vien.astro
import Layout from '../layouts/Layout.astro';

const testimonials = [
  { name: "Nguyễn Thị Hương", job: "Nhân viên hành chính", avatar: "https://randomuser.me/api/portraits/women/1.jpg", text: "Khóa học văn phòng của Sao Việt giúp tôi tự tin hơn hẳn ở công ty. Giảng viên nhiệt tình, cơ sở vật chất tốt. Sau khóa học tôi đã được tăng lương 20%.", rating: 5 },
  { name: "Lê Văn An", job: "Web Developer", avatar: "https://randomuser.me/api/portraits/men/2.jpg", text: "Từ con số 0 về lập trình, sau 4 tháng mình đã xin được việc làm Front-end. Chương trình thực chiến, được làm dự án thật. Cảm ơn trung tâm rất nhiều!", rating: 5 },
  { name: "Phạm Minh Trang", job: "Freelancer", avatar: "https://randomuser.me/api/portraits/women/3.jpg", text: "Học thiết kế đồ họa online nhưng hiệu quả bất ngờ. Đồ án cuối khóa được đánh giá cao, mình đã nhận được hợp đồng thiết kế ngay sau khi tốt nghiệp.", rating: 5 },
  { name: "Trần Văn Nam", job: "Kỹ sư mạng", avatar: "https://randomuser.me/api/portraits/men/4.jpg", text: "Khóa CCNA tại Sao Việt rất chất lượng, thực hành nhiều trên thiết bị thật. Mình đã đậu chứng chỉ và xin được việc tại FPT Telecom.", rating: 5 },
];
---

<Layout>
  <section class="page-header">
    <div class="container">
      <h1>Học viên nói gì?</h1>
      <p class="section-subhead">Hơn 10.000 học viên đã thành công cùng Sao Việt</p>
    </div>
  </section>

  <section class="testimonials-section">
    <div class="container">
      <div class="testimonials-grid">
        {testimonials.map(t => (
          <div class="testimonial-card lazy">
            <div class="testimonial-header">
              <img src={t.avatar} alt={t.name} class="avatar" loading="lazy">
              <div>
                <h3>{t.name}</h3>
                <p class="job">{t.job}</p>
              </div>
            </div>
            <div class="rating">
              {Array.from({ length: t.rating }).map(() => <i class="fas fa-star"></i>)}
            </div>
            <p class="testimonial-text">“{t.text}”</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="video-section">
    <div class="container">
      <h2>Video cảm nhận</h2>
      <div class="video-wrapper">
        <iframe width="560" height="315" src="https://www.youtube.com/embed/dQw4w9WgXcQ?si=abc" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .testimonials-section {
    padding: 60px 0;
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 32px;
  }
  .testimonial-card {
    background: var(--card-bg);
    border-radius: 28px;
    padding: 28px;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
    border: 1px solid var(--border-color);
  }
  .testimonial-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }
  .testimonial-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }
  .avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--primary-blue);
  }
  .testimonial-header h3 {
    font-size: 1.2rem;
    margin-bottom: 4px;
  }
  .job {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .rating {
    color: #f1c40f;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }
  .testimonial-text {
    font-style: italic;
    line-height: 1.6;
    color: var(--text-main);
  }
  .video-section {
    padding: 60px 0;
    text-align: center;
    background: var(--card-bg);
  }
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
    border-radius: 28px;
    box-shadow: var(--shadow-md);
  }
  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
</style>